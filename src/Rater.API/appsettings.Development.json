{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "RateLimiter": "Debug"
    }
  },
  "AllowedHosts": "*",
  "RateLimiter": {
    "Storage": "InMemory",
    "Redis": {
      "ConnectionString": "localhost:6379"
    },
    "Rules": [
      {
        "name": "login-strict",
        "match": {
          "endpoint": "/api/login",
          "httpMethod": "POST"
        },
        "algorithm": "FixedWindow",
        "limit": 5,
        "windowSeconds": 60,
        "keyStrategy": "IpAddress"
      },
      {
        "name": "search-token-bucket",
        "match": {
          "endpoint": "/api/search"
        },
        "algorithm": "TokenBucket",
        "limit": 100,
        "windowSeconds": 60,
        "keyStrategy": "ClientId"
      },
      {
        "name": "global-sliding-window",
        "match": {},
        "algorithm": "SlidingWindowCounter",
        "limit": 200,
        "windowSeconds": 60,
        "keyStrategy": "ClientId"
      }
    ]
  }
}